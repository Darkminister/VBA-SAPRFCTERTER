Option Explicit

' グローバル変数
Private sapConnection As Object
Private dataWb As Workbook
Private dictAppendMode As Object ' シートごとの追記モードを保持

' ====================================================================
' 1. メイン処理 (実行ボタンに登録するプロシージャ)
' ====================================================================
Sub Execute_RFC_Tests_Main()
    Dim testDataFilePath As String
    Dim rfcName As String
    Dim targetCasesStr As String
    Dim targetCases() As String
    Dim wsConfig As Worksheet
    Dim bSuccess As Boolean

    ' 1. テストデータファイルの選択
    testDataFilePath = Application.GetOpenFilename("Excelファイル (*.xlsx), *.xlsx", , "テストデータファイルを選択してください")
    If testDataFilePath = "False" Then Exit Sub

    Application.ScreenUpdating = False

    ' 2. テストデータの読み込み
    Set dataWb = Workbooks.Open(testDataFilePath)
    Set wsConfig = dataWb.Worksheets("Config")
    
    rfcName = wsConfig.Range("B1").Value
    targetCasesStr = CStr(wsConfig.Range("B2").Value)
    
    If rfcName = "" Then
        MsgBox "ConfigシートのB1セルにRFC名が設定されていません。", vbCritical
        GoTo Cleanup
    End If

    ' ターゲットケースの配列化 (空白の場合は要素0の配列)
    If targetCasesStr <> "" Then
        targetCases = Split(targetCasesStr, ",")
    Else
        targetCases = Split("", ",") ' 全件実行用
    End If

    ' 3. 出力先シートの準備と確認（各シートごとの上書き/追加確認）
    Set dictAppendMode = CreateObject("Scripting.Dictionary")
    If Not Prepare_Output_Sheets() Then
        MsgBox "処理をキャンセルしました。", vbInformation
        GoTo Cleanup
    End If

    ' 4. SAPへの接続
    If Not Connect_To_SAP() Then GoTo Cleanup

    ' 5. テストケースの実行
    Call Run_Test_Cases(rfcName, targetCases)

    ' 6. SAPからの切断
    Call Disconnect_SAP
    
    ' =========================================================
    ' ★修正：メッセージを出す「前」にファイルを保存・前面表示する
    ' =========================================================
    Application.ScreenUpdating = True ' 画面更新を再開
    If Not dataWb Is Nothing Then
        dataWb.Save
        dataWb.Activate ' テストデータファイルを前面に出す
        If dataWb.Windows.Count > 0 Then
            dataWb.Windows(1).Visible = True
            dataWb.Windows(1).Activate
        End If
    End If
    
    ' 前面にデータシートが出た状態で完了メッセージを表示
    MsgBox "テストの実行が完了しました。各結果シートを確認してください。", vbInformation
    
    ' 正常終了時のオブジェクト解放
    If Not dataWb Is Nothing Then Set dataWb = Nothing
    If Not dictAppendMode Is Nothing Then Set dictAppendMode = Nothing
    Exit Sub ' ここで処理を終了（Cleanupには行かない）

Cleanup:
    ' キャンセルやエラーで中断した場合の処理
    Application.ScreenUpdating = True
    If Not dataWb Is Nothing Then
        On Error Resume Next
        dataWb.Save
        dataWb.Activate
        On Error GoTo 0
        Set dataWb = Nothing
    End If
    If Not dictAppendMode Is Nothing Then Set dictAppendMode = Nothing
End Sub

' ====================================================================
' 2. SAP接続管理処理
' ====================================================================
Private Function Connect_To_SAP() As Boolean
    Dim sapFunctions As Object
    Dim wsConfig As Worksheet
    Dim sapUser As String
    Dim sapPassword As String
    
    Connect_To_SAP = False
    
    On Error GoTo ErrorHandler
    Set sapFunctions = CreateObject("SAP.Functions")
    Set sapConnection = sapFunctions.Connection

    ' Configシートから接続情報を取得
    Set wsConfig = dataWb.Worksheets("Config")

    ' --- 接続情報 (Configシートの B4～B8 セルから取得) ---
    sapConnection.System = CStr(wsConfig.Range("B4").Value)
    sapConnection.ApplicationServer = CStr(wsConfig.Range("B5").Value)
    sapConnection.SystemNumber = Format(wsConfig.Range("B6").Value, "00")
    sapConnection.Client = Format(wsConfig.Range("B7").Value, "000")
    sapConnection.Language = CStr(wsConfig.Range("B8").Value)
    
    ' ユーザー名のポップアップ入力 (空欄)
    sapUser = InputBox(sapConnection.System & " 環境のユーザー名を入力してください。", "SAPユーザー名入力")
    If sapUser = "" Then
        MsgBox "ユーザー名の入力がキャンセルされたため、処理を中止します。", vbExclamation
        Exit Function
    End If
    sapConnection.User = sapUser
    
    ' パスワードのポップアップ入力
    sapPassword = InputBox(sapConnection.System & " 環境のユーザー [" & sapConnection.User & "] のパスワードを入力してください。" & vbCrLf & vbCrLf & "※入力した文字は画面に表示されるため、背後に注意してください。", "SAPパスワード入力")
    If sapPassword = "" Then
        MsgBox "パスワードの入力がキャンセルされたため、処理を中止します。", vbExclamation
        Exit Function
    End If
    sapConnection.Password = sapPassword

    If sapConnection.Logon(0, True) = True Then
        Connect_To_SAP = True
    Else
        MsgBox "SAPへの接続に失敗しました。ユーザー名とパスワード、または接続情報を確認してください。", vbCritical
    End If
    Exit Function

ErrorHandler:
    MsgBox "SAPコンポーネントの初期化エラー: " & Err.Description, vbCritical
End Function

Private Sub Disconnect_SAP()
    On Error Resume Next
    If Not sapConnection Is Nothing Then
        sapConnection.Logoff
        Set sapConnection = Nothing
    End If
    On Error GoTo 0
End Sub

' ====================================================================
' 3. テストケース実行制御処理
' ====================================================================
Private Sub Run_Test_Cases(rfcName As String, targetCases() As String)
    Dim sapFunctions As Object
    Dim rfcFunc As Object
    Dim caseList As Collection
    Dim caseId As Variant
    Dim runDate As String
    Dim runTime As String
    
    ' 実行対象のケース番号一覧を取得
    Set caseList = Get_Execution_Case_List(targetCases)
    
    ' 各テストケースをループ実行
    For Each caseId In caseList
        ' ★修正ポイント：ケースごとにSAP.Functionsを初期化し、前回のパラメータ（テーブル・構造）を完全にクリアする
        Set sapFunctions = CreateObject("SAP.Functions")
        sapFunctions.Connection = sapConnection
        
        Set rfcFunc = sapFunctions.Add(rfcName)
        If rfcFunc Is Nothing Then
            MsgBox "RFCが見つかりません: " & rfcName, vbCritical
            Exit Sub
        End If
        
        ' パラメータのセット
        Call Set_RFC_Parameters(rfcFunc, CStr(caseId))
        
        ' 実行日時の取得
        runDate = Format(Now, "yyyy/mm/dd")
        runTime = Format(Now, "hh:nn:ss")
        
        ' RFCの実行
        If rfcFunc.Call = True Then
            ' 成功時：結果の取得と出力
            Call Get_And_Write_Results(rfcFunc, CStr(caseId), runDate, runTime)
        Else
            ' 失敗時：システムエラー出力
            Call Write_System_Error_To_Outputs(CStr(caseId), runDate, runTime, rfcFunc.Exception)
        End If
        
        ' オブジェクトの解放（次のループで完全に新規作成させるため）
        Set rfcFunc = Nothing
        Set sapFunctions = Nothing
    Next caseId
End Sub

' ====================================================================
' 4. パラメータ設定処理 (Excel -> SAP)
' ====================================================================
Private Sub Set_RFC_Parameters(rfcFunc As Object, caseId As String)
    Dim ws As Worksheet
    Dim paramObj As Object
    Dim isTable As Boolean
    Dim lastRow As Long, r As Long, c As Integer, lastCol As Integer
    Dim tableRowIdx As Long
    
    ' --- 修正：出力パラメータのリストを取得し、入力処理から除外する ---
    Dim wsConfig As Worksheet
    Dim outputParamsStr As String
    Dim outArr() As String
    Dim isOutput As Boolean
    Dim i As Integer
    
    Set wsConfig = dataWb.Worksheets("Config")
    outputParamsStr = CStr(wsConfig.Range("B3").Value)
    If outputParamsStr <> "" Then
        outArr = Split(outputParamsStr, ",")
    Else
        outArr = Split("", ",")
    End If
    
    For Each ws In dataWb.Worksheets
        If ws.Name <> "Config" Then
            
            ' 現在のシートが出力シートかどうかを判定
            isOutput = False
            For i = 0 To UBound(outArr)
                If UCase(Trim(outArr(i))) = UCase(ws.Name) Then
                    isOutput = True
                    Exit For
                End If
            Next i
            
            ' ★ 出力シートではない（純粋な入力シート）場合のみ、パラメータを設定する
            If Not isOutput Then
                Set paramObj = Nothing
                isTable = False
                
                On Error Resume Next
                Set paramObj = rfcFunc.exports(ws.Name)
                If paramObj Is Nothing Then
                    Set paramObj = rfcFunc.tables(ws.Name)
                    If Not paramObj Is Nothing Then isTable = True
                End If
                If paramObj Is Nothing Then Set paramObj = rfcFunc.imports(ws.Name)
                On Error GoTo 0
                
                If Not paramObj Is Nothing Then
                    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
                    tableRowIdx = 0
                    
                    For r = 2 To lastRow
                        If CStr(ws.Cells(r, 1).Value) = caseId Then
                            If isTable Then
                                paramObj.Rows.Add
                                tableRowIdx = tableRowIdx + 1
                                If ws.Cells(1, 2).Value <> "" Then
                                    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
                                    For c = 2 To lastCol
                                        paramObj.Value(tableRowIdx, ws.Cells(1, c).Value) = CStr(ws.Cells(r, c).Value)
                                    Next c
                                End If
                            Else
                                If ws.Cells(1, 2).Value = "" Then
                                    paramObj.Value = CStr(ws.Cells(r, 2).Value)
                                Else
                                    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
                                    For c = 2 To lastCol
                                        paramObj(ws.Cells(1, c).Value) = CStr(ws.Cells(r, c).Value)
                                    Next c
                                End If
                            End If
                        End If
                    Next r
                End If
            End If ' Not isOutput の終端
        End If
    Next ws
End Sub

' ====================================================================
' 5. 結果取得・出力処理 (SAP -> Excel横持ち出力)
' ====================================================================
Private Sub Get_And_Write_Results(rfcFunc As Object, caseId As String, runDate As String, runTime As String)
    Dim wsConfig As Worksheet
    Dim wsParamDef As Worksheet
    Dim paramName As String
    Dim paramObj As Object
    Dim isTable As Boolean
    Dim outputParamsStr As String
    Dim outputParams() As String
    Dim i As Integer, cIdx As Integer
    Dim nextRow As Long, lastCol As Integer
    Dim fldName As String
    
    Set wsConfig = dataWb.Worksheets("Config")
    outputParamsStr = CStr(wsConfig.Range("B3").Value)
    If outputParamsStr = "" Then Exit Sub
    
    outputParams = Split(outputParamsStr, ",")
    
    For i = 0 To UBound(outputParams)
        paramName = Trim(outputParams(i))
        If paramName <> "" Then
            Set paramObj = Nothing
            isTable = False
            
            On Error Resume Next
            Set paramObj = rfcFunc.imports(paramName)
            If paramObj Is Nothing Then
                Set paramObj = rfcFunc.tables(paramName)
                If Not paramObj Is Nothing Then isTable = True
            End If
            If paramObj Is Nothing Then Set paramObj = rfcFunc.exports(paramName)
            On Error GoTo 0
            
            If Not paramObj Is Nothing Then
                ' 出力用シートはPrepare_Output_Sheetsで作成済のため必ず存在する
                Set wsParamDef = dataWb.Worksheets(paramName)
                lastCol = wsParamDef.Cells(1, wsParamDef.Columns.Count).End(xlToLeft).Column
                
                If isTable Then
                    ' --- テーブル出力 ---
                    Dim rowCnt As Long, rIdx As Long
                    rowCnt = paramObj.RowCount
                    
                    If rowCnt = 0 Then
                        nextRow = wsParamDef.Cells(wsParamDef.Rows.Count, 1).End(xlUp).Row + 1
                        wsParamDef.Cells(nextRow, 1).Value = caseId
                        wsParamDef.Cells(nextRow, 2).Value = runDate
                        wsParamDef.Cells(nextRow, 3).Value = runTime
                        wsParamDef.Cells(nextRow, 4).Value = "(Empty)"
                    Else
                        If lastCol < 4 Then
                            nextRow = wsParamDef.Cells(wsParamDef.Rows.Count, 1).End(xlUp).Row + 1
                            wsParamDef.Cells(nextRow, 1).Value = caseId
                            wsParamDef.Cells(nextRow, 2).Value = runDate
                            wsParamDef.Cells(nextRow, 3).Value = runTime
                            wsParamDef.Cells(nextRow, 4).Value = "ERROR: 1行目のD列以降にSAPの項目名(TYPE等)を定義してください"
                        Else
                            For rIdx = 1 To rowCnt
                                nextRow = wsParamDef.Cells(wsParamDef.Rows.Count, 1).End(xlUp).Row + 1
                                wsParamDef.Cells(nextRow, 1).Value = caseId
                                wsParamDef.Cells(nextRow, 2).Value = runDate
                                wsParamDef.Cells(nextRow, 3).Value = runTime
                                
                                For cIdx = 4 To lastCol
                                    fldName = wsParamDef.Cells(1, cIdx).Value
                                    On Error Resume Next
                                    wsParamDef.Cells(nextRow, cIdx).Value = CStr(paramObj.Value(rIdx, fldName))
                                    On Error GoTo 0
                                Next cIdx
                            Next rIdx
                        End If
                    End If
                Else
                    ' --- 構造・スカラー出力 ---
                    nextRow = wsParamDef.Cells(wsParamDef.Rows.Count, 1).End(xlUp).Row + 1
                    wsParamDef.Cells(nextRow, 1).Value = caseId
                    wsParamDef.Cells(nextRow, 2).Value = runDate
                    wsParamDef.Cells(nextRow, 3).Value = runTime
                    
                    If lastCol >= 4 Then
                        For cIdx = 4 To lastCol
                            fldName = wsParamDef.Cells(1, cIdx).Value
                            On Error Resume Next
                            wsParamDef.Cells(nextRow, cIdx).Value = CStr(paramObj(fldName))
                            On Error GoTo 0
                        Next cIdx
                    Else
                        ' スカラーのフォールバック
                        On Error Resume Next
                        Dim valStr As String
                        valStr = ""
                        valStr = CStr(paramObj.Value)
                        If Err.Number = 0 Then
                            wsParamDef.Cells(nextRow, 4).Value = valStr
                        Else
                            wsParamDef.Cells(nextRow, 4).Value = "ERROR: 1行目のD列以降にSAPの項目名を定義してください"
                        End If
                        On Error GoTo 0
                    End If
                End If
            End If
        End If
    Next i
End Sub

' ====================================================================
' 6. ユーティリティ処理
' ====================================================================
' 各出力シートの準備（上書き・追加の確認とヘッダ生成）
Private Function Prepare_Output_Sheets() As Boolean
    Dim wsConfig As Worksheet
    Dim outputParamsStr As String
    Dim outputParams() As String
    Dim i As Integer
    Dim paramName As String
    Dim ws As Worksheet
    Dim ans As Integer
    
    Prepare_Output_Sheets = False
    
    Set wsConfig = dataWb.Worksheets("Config")
    outputParamsStr = CStr(wsConfig.Range("B3").Value)
    If outputParamsStr = "" Then
        Prepare_Output_Sheets = True ' 出力なしで続行
        Exit Function
    End If
    
    outputParams = Split(outputParamsStr, ",")
    
    For i = 0 To UBound(outputParams)
        paramName = Trim(outputParams(i))
        If paramName <> "" Then
            Set ws = Nothing
            On Error Resume Next
            Set ws = dataWb.Worksheets(paramName)
            On Error GoTo 0
            
            If Not ws Is Nothing Then
                ' シートが存在する場合、データ（2行目以降）があるか確認
                If ws.Cells(ws.Rows.Count, 1).End(xlUp).Row > 1 Then
                    ans = MsgBox("出力先シート「" & paramName & "」には既にデータが存在します。" & vbCrLf & "既存のデータをクリアして上書きしますか？" & vbCrLf & vbCrLf & "[はい] : 上書き（データをクリア）" & vbCrLf & "[いいえ] : 追加（末尾に追記）" & vbCrLf & "[キャンセル] : 処理を中止", vbYesNoCancel + vbQuestion, "出力方法の確認 (" & paramName & ")")
                    If ans = vbYes Then
                        ws.Rows("2:" & ws.Rows.Count).ClearContents ' クリア実行
                        dictAppendMode(paramName) = False
                    ElseIf ans = vbNo Then
                        dictAppendMode(paramName) = True
                    Else
                        Exit Function ' キャンセル時
                    End If
                Else
                    dictAppendMode(paramName) = False
                End If
                
                ' ヘッダが欠損している場合は補完
                If ws.Cells(1, 1).Value = "" Then ws.Cells(1, 1).Value = "ケースID"
                If ws.Cells(1, 2).Value = "" Then ws.Cells(1, 2).Value = "実行日付"
                If ws.Cells(1, 3).Value = "" Then ws.Cells(1, 3).Value = "実行時刻"
            Else
                ' シートが存在しない場合はエラーメッセージを出して中止
                MsgBox "出力指定されたシート「" & paramName & "」が見つかりません。" & vbCrLf & "出力結果を受け取るシートは必ず事前に作成してください。", vbCritical, "エラー"
                Exit Function
            End If
        End If
    Next i
    
    Prepare_Output_Sheets = True
End Function

' システムエラー発生時に全出力シートへエラーを書き込む
Private Sub Write_System_Error_To_Outputs(caseId As String, runDate As String, runTime As String, errMsg As String)
    Dim paramName As Variant
    Dim ws As Worksheet
    Dim nextRow As Long
    
    For Each paramName In dictAppendMode.Keys
        Set ws = dataWb.Worksheets(paramName)
        nextRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row + 1
        ws.Cells(nextRow, 1).Value = caseId
        ws.Cells(nextRow, 2).Value = runDate
        ws.Cells(nextRow, 3).Value = runTime
        ws.Cells(nextRow, 4).Value = "SYSTEM_ERROR: " & errMsg
    Next paramName
End Sub

Private Function Get_Execution_Case_List(targetCases() As String) As Collection
    Dim col As New Collection
    Dim ws As Worksheet
    Dim r As Long, lastRow As Long
    Dim caseId As String
    
    If UBound(targetCases) >= 0 Then
        If targetCases(0) <> "" Then
            Dim i As Integer
            For i = 0 To UBound(targetCases)
                col.Add Trim(targetCases(i))
            Next i
            Set Get_Execution_Case_List = col
            Exit Function
        End If
    End If
    
    For Each ws In dataWb.Worksheets
        If ws.Name <> "Config" Then
            lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
            On Error Resume Next
            For r = 2 To lastRow
                caseId = CStr(ws.Cells(r, 1).Value)
                If caseId <> "" Then
                    col.Add caseId, CStr(caseId)
                End If
            Next r
            On Error GoTo 0
            Exit For
        End If
    Next ws
    
    Set Get_Execution_Case_List = col
End Function
