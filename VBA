Option Explicit

' グローバル変数
Private sapConnection As Object
Private dataWb As Workbook
Private isAppendMode As Boolean

' ====================================================================
' 1. メイン処理 (実行ボタンに登録するプロシージャ)
' ====================================================================
Sub Execute_RFC_Tests_Main()
    Dim testDataFilePath As String
    Dim rfcName As String
    Dim targetCasesStr As String
    Dim targetCases() As String
    Dim wsConfig As Worksheet
    Dim bSuccess As Boolean

    ' 1. テストデータファイルの選択
    testDataFilePath = Application.GetOpenFilename("Excelファイル (*.xlsx), *.xlsx", , "テストデータファイルを選択してください")
    If testDataFilePath = "False" Then Exit Sub

    Application.ScreenUpdating = False

    ' 2. テストデータの読み込み
    Set dataWb = Workbooks.Open(testDataFilePath)
    Set wsConfig = dataWb.Worksheets("Config")
    
    rfcName = wsConfig.Range("B1").Value
    targetCasesStr = CStr(wsConfig.Range("B2").Value)
    
    If rfcName = "" Then
        MsgBox "ConfigシートのB1セルにRFC名が設定されていません。", vbCritical
        GoTo Cleanup
    End If

    ' ターゲットケースの配列化 (空白の場合は要素0の配列)
    If targetCasesStr <> "" Then
        targetCases = Split(targetCasesStr, ",")
    Else
        targetCases = Split("", ",") ' 全件実行用
    End If

    ' 3. 出力先シート (result) の準備と確認
    If Not Prepare_Result_Sheet() Then
        MsgBox "処理をキャンセルしました。", vbInformation
        GoTo Cleanup
    End If

    ' 4. SAPへの接続
    If Not Connect_To_SAP() Then GoTo Cleanup

    ' 5. テストケースの実行
    Call Run_Test_Cases(rfcName, targetCases)

    ' 6. SAPからの切断
    Call Disconnect_SAP
    
    MsgBox "テストの実行が完了しました。resultシートを確認してください。", vbInformation

Cleanup:
    ' クリーンアップとファイルの保存
    If Not dataWb Is Nothing Then
        dataWb.Save
        dataWb.Close False
        Set dataWb = Nothing
    End If
    Application.ScreenUpdating = True
End Sub

' ====================================================================
' 2. SAP接続管理処理
' ====================================================================
Private Function Connect_To_SAP() As Boolean
    Dim sapFunctions As Object
    Dim wsConfig As Worksheet
    Dim sapUser As String
    Dim sapPassword As String
    
    Connect_To_SAP = False
    
    On Error GoTo ErrorHandler
    Set sapFunctions = CreateObject("SAP.Functions")
    Set sapConnection = sapFunctions.Connection

    ' Configシートから接続情報を取得
    Set wsConfig = dataWb.Worksheets("Config")

    ' --- 接続情報 (Configシートの B4～B10 セルから取得) ---
    sapConnection.System = CStr(wsConfig.Range("B4").Value)
    sapConnection.ApplicationServer = CStr(wsConfig.Range("B5").Value)
    ' 前ゼロが消えていても自動で補完 (SystemNumberは2桁、Clientは3桁)
    sapConnection.SystemNumber = Format(wsConfig.Range("B6").Value, "00")
    sapConnection.Client = Format(wsConfig.Range("B7").Value, "000")
    
    ' ユーザー名のポップアップ入力 (デフォルト値としてConfigのB8をセット)
    sapUser = InputBox(sapConnection.System & " 環境のユーザー名を入力してください。", "SAPユーザー名入力", CStr(wsConfig.Range("B8").Value))
    
    ' キャンセルまたは未入力の場合は処理を中断
    If sapUser = "" Then
        MsgBox "ユーザー名の入力がキャンセルされたため、処理を中止します。", vbExclamation
        Connect_To_SAP = False
        Exit Function
    End If
    sapConnection.User = sapUser
    
    ' パスワードのポップアップ入力
    sapPassword = InputBox(sapConnection.System & " 環境のユーザー [" & sapConnection.User & "] のパスワードを入力してください。" & vbCrLf & vbCrLf & "※入力した文字は画面に表示されるため、背後に注意してください。", "SAPパスワード入力")
    
    ' キャンセルまたは未入力の場合は処理を中断
    If sapPassword = "" Then
        MsgBox "パスワードの入力がキャンセルされたため、処理を中止します。", vbExclamation
        Connect_To_SAP = False
        Exit Function
    End If
    
    sapConnection.Password = sapPassword
    sapConnection.Language = CStr(wsConfig.Range("B10").Value)

    If sapConnection.Logon(0, True) = True Then
        Connect_To_SAP = True
    Else
        MsgBox "SAPへの接続に失敗しました。ユーザー名とパスワード、またはConfigシートの接続情報を確認してください。", vbCritical
    End If
    Exit Function

ErrorHandler:
    MsgBox "SAPコンポーネントの初期化エラー: " & Err.Description, vbCritical
End Function

Private Sub Disconnect_SAP()
    On Error Resume Next
    If Not sapConnection Is Nothing Then
        sapConnection.Logoff
        Set sapConnection = Nothing
    End If
    On Error GoTo 0
End Sub

' ====================================================================
' 3. テストケース実行制御処理
' ====================================================================
Private Sub Run_Test_Cases(rfcName As String, targetCases() As String)
    Dim sapFunctions As Object
    Dim rfcFunc As Object
    Dim caseList As Collection
    Dim caseId As Variant
    
    Set sapFunctions = CreateObject("SAP.Functions")
    sapFunctions.Connection = sapConnection

    ' 実行対象のケース番号一覧を取得（全件の場合はシートから抽出）
    Set caseList = Get_Execution_Case_List(targetCases)
    
    ' 結果出力用のヘッダ作成
    Call Initialize_Results_Sheet
    
    ' 各テストケースをループ実行
    For Each caseId In caseList
        ' RFCオブジェクトの初期化（前回のデータをクリアするため毎回生成）
        Set rfcFunc = sapFunctions.Add(rfcName)
        If rfcFunc Is Nothing Then
            MsgBox "RFCが見つかりません: " & rfcName, vbCritical
            Exit Sub
        End If
        
        ' パラメータのセット
        Call Set_RFC_Parameters(rfcFunc, CStr(caseId))
        
        ' RFCの実行
        Dim runTime As String
        runTime = Format(Now, "yyyy/mm/dd hh:nn:ss")
        
        If rfcFunc.Call = True Then
            ' 成功時：結果の取得と出力
            Call Get_And_Write_Results(rfcFunc, CStr(caseId), runTime)
        Else
            ' 失敗時：エラーログ出力
            Call Write_Single_Result(CStr(caseId), runTime, "SYSTEM_ERROR", 0, "Exception", rfcFunc.Exception)
        End If
        
        Set rfcFunc = Nothing
    Next caseId
End Sub

' ====================================================================
' 4. パラメータ設定処理 (Excel -> SAP)
' ====================================================================
Private Sub Set_RFC_Parameters(rfcFunc As Object, caseId As String)
    Dim ws As Worksheet
    Dim paramObj As Object
    Dim isTable As Boolean
    Dim lastRow As Long, r As Long, c As Integer, lastCol As Integer
    Dim tableRowIdx As Long
    
    ' Dataブック内の全シートをループ
    For Each ws In dataWb.Worksheets
        ' 設定用シートは除外
        If ws.Name <> "Config" And LCase(ws.Name) <> "result" Then
            
            ' RFCオブジェクト内の対象パラメータを特定
            Set paramObj = Nothing
            isTable = False
            
            On Error Resume Next
            Set paramObj = rfcFunc.exports(ws.Name)
            If paramObj Is Nothing Then
                Set paramObj = rfcFunc.tables(ws.Name)
                If Not paramObj Is Nothing Then isTable = True
            End If
            If paramObj Is Nothing Then Set paramObj = rfcFunc.imports(ws.Name) ' Changing等
            On Error GoTo 0
            
            If Not paramObj Is Nothing Then
                lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
                tableRowIdx = 0
                
                For r = 2 To lastRow
                    ' 該当ケース番号の行のみ処理
                    If CStr(ws.Cells(r, 1).Value) = caseId Then
                        If isTable Then
                            ' [テーブル] の場合
                            paramObj.Rows.Add
                            tableRowIdx = tableRowIdx + 1
                            ' 1行目に項目名があるか確認
                            If ws.Cells(1, 2).Value <> "" Then
                                lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
                                For c = 2 To lastCol
                                    paramObj.Value(tableRowIdx, ws.Cells(1, c).Value) = CStr(ws.Cells(r, c).Value)
                                Next c
                            End If
                        Else
                            ' [スカラー または 構造] の場合
                            If ws.Cells(1, 2).Value = "" Then
                                ' スカラー (1行目B列が空白)
                                paramObj.Value = CStr(ws.Cells(r, 2).Value)
                            Else
                                ' 構造 (1行目に項目名あり)
                                lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
                                For c = 2 To lastCol
                                    paramObj(ws.Cells(1, c).Value) = CStr(ws.Cells(r, c).Value)
                                Next c
                            End If
                        End If
                    End If
                Next r
            End If
        End If
    Next ws
End Sub

' ====================================================================
' 5. 結果取得・出力処理 (SAP -> Excel)
' ====================================================================
Private Sub Get_And_Write_Results(rfcFunc As Object, caseId As String, runTime As String)
    Dim wsConfig As Worksheet
    Dim wsParamDef As Worksheet
    Dim paramName As String
    Dim paramObj As Object
    Dim isTable As Boolean
    Dim outputParamsStr As String
    Dim outputParams() As String
    Dim i As Integer
    
    Set wsConfig = dataWb.Worksheets("Config")
    outputParamsStr = CStr(wsConfig.Range("B3").Value)
    
    If outputParamsStr = "" Then Exit Sub ' 出力指定がない場合は何もしない
    
    outputParams = Split(outputParamsStr, ",")
    
    ' 出力指定されたパラメータをループ
    For i = 0 To UBound(outputParams)
        paramName = Trim(outputParams(i))
        If paramName <> "" Then
            Set paramObj = Nothing
            isTable = False
            
            ' パラメータオブジェクトの取得
            On Error Resume Next
            Set paramObj = rfcFunc.imports(paramName)
            If paramObj Is Nothing Then
                Set paramObj = rfcFunc.tables(paramName)
                If Not paramObj Is Nothing Then isTable = True
            End If
            If paramObj Is Nothing Then Set paramObj = rfcFunc.exports(paramName)
            On Error GoTo 0
            
            If Not paramObj Is Nothing Then
                ' 項目名を取得するために、同名のパラメータシートを探す
                Set wsParamDef = Nothing
                On Error Resume Next
                Set wsParamDef = dataWb.Worksheets(paramName)
                On Error GoTo 0
                
                If isTable Then
                    ' [テーブル出力]
                    Dim rowCnt As Long, rIdx As Long, cIdx As Integer, fldName As String
                    rowCnt = paramObj.RowCount
                    
                    If rowCnt = 0 Then
                        Call Write_Single_Result(caseId, runTime, paramName, 0, "", "(Empty)")
                    Else
                        For rIdx = 1 To rowCnt
                            If Not wsParamDef Is Nothing And wsParamDef.Cells(1, 2).Value <> "" Then
                                ' シートに項目名定義がある場合
                                For cIdx = 2 To wsParamDef.Cells(1, wsParamDef.Columns.Count).End(xlToLeft).Column
                                    fldName = wsParamDef.Cells(1, cIdx).Value
                                    Call Write_Single_Result(caseId, runTime, paramName, rIdx, fldName, CStr(paramObj.Value(rIdx, fldName)))
                                Next cIdx
                            Else
                                ' 項目名定義がない場合は警告のみ出力（COMの制約上、動的列名取得が難しいため）
                                Call Write_Single_Result(caseId, runTime, paramName, rIdx, "N/A", "Excelシートに項目名定義がありません")
                            End If
                        Next rIdx
                    End If
                Else
                    ' [スカラー または 構造出力]
                    If Not wsParamDef Is Nothing Then
                        If wsParamDef.Cells(1, 2).Value = "" Then
                            ' スカラー定義
                            Call Write_Single_Result(caseId, runTime, paramName, 1, "", CStr(paramObj.Value))
                        Else
                            ' 構造定義
                            For cIdx = 2 To wsParamDef.Cells(1, wsParamDef.Columns.Count).End(xlToLeft).Column
                                fldName = wsParamDef.Cells(1, cIdx).Value
                                Call Write_Single_Result(caseId, runTime, paramName, 1, fldName, CStr(paramObj(fldName)))
                            Next cIdx
                        End If
                    Else
                        ' シート定義がない場合、スカラーとして取得を試みる
                        On Error Resume Next
                        Call Write_Single_Result(caseId, runTime, paramName, 1, "", CStr(paramObj.Value))
                        On Error GoTo 0
                    End If
                End If
            End If
        End If
    Next i
End Sub

' ====================================================================
' 6. ユーティリティ処理 (Excel書き込み・データ抽出)
' ====================================================================
Private Function Prepare_Result_Sheet() As Boolean
    Dim ws As Worksheet
    Dim sheetExists As Boolean
    Dim ans As Integer
    
    sheetExists = False
    For Each ws In dataWb.Worksheets
        If LCase(ws.Name) = "result" Then
            sheetExists = True
            Exit For
        End If
    Next ws
    
    If Not sheetExists Then
        ' 新規作成 (一番最後に追加)
        Set ws = dataWb.Worksheets.Add(After:=dataWb.Worksheets(dataWb.Worksheets.Count))
        ws.Name = "result"
        isAppendMode = False ' 新規作成なのでヘッダを作成する
        Prepare_Result_Sheet = True
    Else
        ' 既存の場合の確認
        ans = MsgBox("シート「result」が既に存在します。" & vbCrLf & "既存のデータをクリアして上書きしますか？" & vbCrLf & vbCrLf & "[はい] : 上書き（既存データをクリア）" & vbCrLf & "[いいえ] : 追加（既存データの末尾に追記）", vbYesNoCancel + vbQuestion, "出力方法の確認")
        
        If ans = vbYes Then
            isAppendMode = False ' クリアする
            Prepare_Result_Sheet = True
        ElseIf ans = vbNo Then
            isAppendMode = True  ' クリアしない
            Prepare_Result_Sheet = True
        Else
            Prepare_Result_Sheet = False ' キャンセル
        End If
    End If
End Function

Private Sub Initialize_Results_Sheet()
    Dim ws As Worksheet
    Set ws = dataWb.Worksheets("result")
    
    If Not isAppendMode Then
        ws.Cells.Clear
        ws.Range("A1:F1").Value = Array("テストケース番号", "実行日時", "パラメータ名", "行番号", "項目名", "値")
        ws.Range("A1:F1").Interior.Color = RGB(220, 230, 241)
        ws.Range("A1:F1").Font.Bold = True
    End If
End Sub

Private Sub Write_Single_Result(caseId As String, runTime As String, paramName As String, rowIdx As Long, fldName As String, val As String)
    Dim ws As Worksheet
    Dim nextRow As Long
    Set ws = dataWb.Worksheets("result")
    nextRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row + 1
    
    ws.Cells(nextRow, 1).Value = caseId
    ws.Cells(nextRow, 2).Value = runTime
    ws.Cells(nextRow, 3).Value = paramName
    ws.Cells(nextRow, 4).Value = IIf(rowIdx = 0, "-", rowIdx)
    ws.Cells(nextRow, 5).Value = fldName
    ws.Cells(nextRow, 6).Value = val
End Sub

Private Function Get_Execution_Case_List(targetCases() As String) As Collection
    Dim col As New Collection
    Dim ws As Worksheet
    Dim r As Long, lastRow As Long
    Dim caseId As String
    
    If UBound(targetCases) >= 0 And targetCases(0) <> "" Then
        ' 指定がある場合はそれを返す
        Dim i As Integer
        For i = 0 To UBound(targetCases)
            col.Add Trim(targetCases(i))
        Next i
    Else
        ' 指定がない場合は、最初のパラメータシートから一意のケース番号を抽出
        For Each ws In dataWb.Worksheets
            If ws.Name <> "Config" And LCase(ws.Name) <> "result" Then
                lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
                On Error Resume Next
                For r = 2 To lastRow
                    caseId = CStr(ws.Cells(r, 1).Value)
                    If caseId <> "" Then
                        col.Add caseId, CStr(caseId) ' Keyを指定して重複を排除
                    End If
                Next r
                On Error GoTo 0
                Exit For ' 1つのシートから取れればOK
            End If
        Next ws
    End If
    Set Get_Execution_Case_List = col
End Function
